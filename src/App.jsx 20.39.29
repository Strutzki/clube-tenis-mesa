    logo: { width:88, height:88, borderRadius:"50%", overflow:"hidden", border:"3px solid rgba(26,115,200,0.5)", marginBottom:20, boxShadow:"0 0 30px rgba(26,115,200,0.3)" },
    title: { fontSize:18, fontWeight:800, color:"#e8edf2", marginBottom:4, textAlign:"center" },
    sub: { fontSize:12, color:"#6b7a8d", marginBottom:28, textAlign:"center" },
    card: { background:"#111d2b", borderRadius:16, padding:22, width:"100%", maxWidth:360, border:"1px solid rgba(255,255,255,0.06)" },
    btn: (bg) => ({ background:bg||"linear-gradient(135deg,#1a73c8,#0d5aa7)", color:"#fff", border:"none", borderRadius:11, padding:"13px", fontSize:14, fontWeight:700, cursor:"pointer", width:"100%", marginBottom:10 }),
    outline: { background:"transparent", color:"#4da3ff", border:"1px solid rgba(26,115,200,0.4)", borderRadius:11, padding:"13px", fontSize:14, fontWeight:600, cursor:"pointer", width:"100%", marginBottom:10 },
    input: { background:"#0a1628", border:"1px solid rgba(255,255,255,0.1)", borderRadius:10, color:"#e8edf2", padding:"11px 12px", fontSize:14, width:"100%", marginBottom:10, outline:"none", boxSizing:"border-box" },
    label: { fontSize:11, fontWeight:700, color:"#8b9ab5", textTransform:"uppercase", letterSpacing:0.8, display:"block", marginBottom:5 },
    err: { color:"#f87171", fontSize:12, textAlign:"center", marginTop:8 },
    back: { background:"none", border:"none", color:"#6b7a8d", cursor:"pointer", fontSize:13, marginBottom:16, display:"flex", alignItems:"center", gap:4 },
  };

  if (mode === "select") return (
    <div style={s.wrap}>
      <div style={s.logo}><img src={LOGO} alt="Logo" style={{width:"100%",height:"100%",objectFit:"cover"}}/></div>
      <div style={s.title}>Clube Do Tênis de Mesa</div>
      <div style={s.sub}>Clube do Tênis de Mesa · Temporada 2026</div>
      <div style={s.card}>
        <button style={s.btn()} onClick={() => setMode("admin")}>🔐 Entrar como Administrador</button>
        <button style={s.btn("linear-gradient(135deg,#166534,#15803d)")} onClick={() => setMode("athlete")}>🏓 Sou atleta — ver meus jogos</button>
        <button style={s.outline} onClick={() => setMode("inscricao")}>📝 Quero me inscrever</button>
      </div>
      <button style={s.btn("linear-gradient(135deg,#374151,#1f2937)")} onClick={() => setMode("regulamento")}>📋 Regulamento Oficial</button>
      <div style={{fontSize:11,color:"#374151",marginTop:8}}>🔒 Acesso restrito por perfil</div>
    </div>
  );

  if (mode === "admin") return (
    <div style={s.wrap}>
      <div style={s.logo}><img src={LOGO} alt="Logo" style={{width:"100%",height:"100%",objectFit:"cover"}}/></div>
      <div style={s.card}>
        <button style={s.back} onClick={() => setMode("select")}>← Voltar</button>
        <div style={s.title}>Acesso Admin</div>
        <br/>
        <label style={s.label}>Usuário</label>
        <input style={s.input} value={user} onChange={e=>setUser(e.target.value)} placeholder="admin" onKeyDown={e=>e.key==="Enter"&&doAdmin()}/>
        <label style={s.label}>PIN (4 dígitos)</label>
        <input style={{...s.input,marginBottom:10,letterSpacing:8,fontSize:22,textAlign:"center",fontWeight:800}} type="tel" inputMode="numeric" maxLength={4} value={pass} onChange={e=>setPass(e.target.value.replace(/\D/g,"").slice(0,4))} placeholder="····" onKeyDown={e=>e.key==="Enter"&&doAdmin()}/>
        <button style={s.btn()} onClick={doAdmin}>Entrar</button>
        {err && <div style={s.err}>🔒 {err}</div>}
      </div>
    </div>
  );

  if (mode === "athlete") return (
    <div style={s.wrap}>
      <div style={s.logo}><img src={LOGO} alt="Logo" style={{width:"100%",height:"100%",objectFit:"cover"}}/></div>
      <div style={s.card}>
        <button style={s.back} onClick={() => setMode("select")}>← Voltar</button>
        <div style={s.title}>Acesso Atleta</div>
        <br/>
        <label style={s.label}>Seu WhatsApp (com DDD)</label>
        <input style={s.input} value={phone} onChange={e=>setPhone(e.target.value)} placeholder="31999999999" type="tel" onKeyDown={e=>e.key==="Enter"&&doAthlete()}/>

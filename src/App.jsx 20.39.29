    if (user===ADMIN_USER && pass===ADMIN_PASS) { onLogin(); }
    else { setErr("Usuário ou senha incorretos."); setTimeout(()=>setErr(""),3000); }
  }
  function doAthlete() {
    const clean = phone.replace(/\D/g,"");
    const found = athletes.find(a => a.phone.replace(/\D/g,"") === clean && a.status === "ativo");
    if (found) onAthleteLogin(found);
    else { setErr("Telefone não encontrado ou cadastro não aprovado."); setTimeout(()=>setErr(""),3000); }
  }
}

// ── FORMULÁRIO DE INSCRIÇÃO (público) ────────────────────────────────────────
function InscricaoForm({ onBack, onSubmit }) {
  const [step, setStep] = useState(1); // 1=dados, 2=lgpd, 3=regulamento, 4=sucesso
  const [name, setName] = useState(""), [phone, setPhone] = useState("");
  const [fed, setFed] = useState("nao"), [rating, setRating] = useState("");
  const [aceiteLGPD, setAceiteLGPD] = useState(false);
  const [aceiteReg, setAceiteReg] = useState(false);
  const [lerReg, setLerReg] = useState(false);

  const s = {
    wrap: { minHeight:"100vh", background:"#0a1628", display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"flex-start", padding:"24px 16px 40px", fontFamily:"Inter,sans-serif" },
    card: { background:"#111d2b", borderRadius:16, padding:22, width:"100%", maxWidth:420, border:"1px solid rgba(255,255,255,0.06)" },
    title: { fontSize:15, fontWeight:800, color:"#e8edf2", marginBottom:4 },
    sub: { fontSize:11, color:"#6b7a8d", marginBottom:16 },
    label: { fontSize:11, fontWeight:700, color:"#8b9ab5", textTransform:"uppercase", letterSpacing:0.8, display:"block", marginBottom:5, marginTop:14 },
    input: { background:"#0a1628", border:"1px solid rgba(255,255,255,0.1)", borderRadius:10, color:"#e8edf2", padding:"11px 12px", fontSize:14, width:"100%", outline:"none", boxSizing:"border-box" },
    select: { background:"#0a1628", border:"1px solid rgba(255,255,255,0.1)", borderRadius:10, color:"#e8edf2", padding:"11px 12px", fontSize:14, width:"100%", outline:"none" },
    btn: (dis) => ({ background: dis?"#1f2937":"linear-gradient(135deg,#1a73c8,#0d5aa7)", color: dis?"#6b7a8d":"#fff", border:"none", borderRadius:11, padding:"13px", fontSize:14, fontWeight:700, cursor: dis?"default":"pointer", width:"100%", marginTop:16 }),
    back: { background:"none", border:"none", color:"#6b7a8d", cursor:"pointer", fontSize:13, marginBottom:16, display:"flex", alignItems:"center", gap:4 },
    steps: { display:"flex", gap:6, marginBottom:20, justifyContent:"center" },
    stepDot: (ativo, feito) => ({ width:28, height:4, borderRadius:2, background: feito?"#4ade80": ativo?"#4da3ff":"rgba(255,255,255,0.1)" }),
    checkRow: { display:"flex", gap:12, alignItems:"flex-start", padding:"14px", background:"rgba(255,255,255,0.03)", borderRadius:10, border:"1px solid rgba(255,255,255,0.07)", marginTop:10, cursor:"pointer" },
    checkBox: (checked) => ({ width:20, height:20, borderRadius:5, border:`2px solid ${checked?"#4da3ff":"rgba(255,255,255,0.2)"}`, background: checked?"#4da3ff":"transparent", display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0, marginTop:1 }),
    box: (cor) => ({ background:`${cor}11`, border:`1px solid ${cor}33`, borderLeft:`3px solid ${cor}`, borderRadius:8, padding:"10px 12px", marginTop:10, fontSize:12, color:"#8b9ab5", lineHeight:1.6 }),
  };

  // Passos de progresso
  const Steps = () => (
    <div style={s.steps}>
      {[1,2,3].map(n => <div key={n} style={s.stepDot(step===n, step>n)}/>)}
    </div>
  );

  // ── STEP 1: Dados pessoais ──────────────────────────────────────────────────
  if (step === 1) return (
    <div style={s.wrap}>
      <div style={{...s.card, marginTop:20}}>
        {onBack && <button style={s.back} onClick={onBack}>← Voltar</button>}
        <Steps/>
        <div style={s.title}>📝 Inscrição — Dados Pessoais</div>
        <div style={s.sub}>Passo 1 de 3 · Seus dados de cadastro</div>

        <label style={s.label}>Nome completo *</label>
        <input style={s.input} value={name} onChange={e=>setName(e.target.value)} placeholder="Seu nome completo"/>

        <label style={s.label}>WhatsApp (com DDD) *</label>
        <input style={s.input} value={phone} onChange={e=>setPhone(e.target.value)} placeholder="31999999999" type="tel"/>

        <label style={s.label}>É federado pela CBTM?</label>
        <select style={s.select} value={fed} onChange={e=>setFed(e.target.value)}>
          <option value="nao">Não sou federado</option>
          <option value="sim">Sim, sou federado</option>
        </select>

        {fed === "sim" && <>
          <label style={s.label}>Seu rating CBTM (TTR)</label>
          <input style={s.input} value={rating} onChange={e=>setRating(e.target.value)} placeholder="Ex: 1850" type="number"/>
        </>}

        <div style={{...s.box("#facc15"), marginTop:14}}>
          <strong style={{color:"#facc15"}}>⚠️ Atletas federados CBTM</strong><br/>
          Verifique com sua federação se a participação em eventos não-oficiais é permitida conforme a Nota CBTM 183/2025.
        </div>

        <button style={s.btn(!name.trim()||!phone.trim())} onClick={()=>{ if(name.trim()&&phone.trim()) setStep(2); }} disabled={!name.trim()||!phone.trim()}>
          Continuar →
        </button>
      </div>
    </div>
  );

  // ── STEP 2: LGPD ───────────────────────────────────────────────────────────
  if (step === 2) return (
    <div style={s.wrap}>
      <div style={{...s.card, marginTop:20}}>
        <button style={s.back} onClick={()=>setStep(1)}>← Voltar</button>
        <Steps/>
        <div style={s.title}>🔒 Privacidade & LGPD</div>
        <div style={s.sub}>Passo 2 de 3 · Consentimento sobre seus dados</div>

        <div style={{...s.box("#4da3ff"), marginTop:8}}>
          <strong style={{color:"#4da3ff", fontSize:13}}>Quais dados coletamos</strong><br/><br/>
          <strong style={{color:"#e8edf2"}}>Nome completo e WhatsApp</strong> — para identificação, comunicação sobre suas partidas e publicação no ranking oficial do Circuito.<br/><br/>
          <strong style={{color:"#e8edf2"}}>Situação federativa e rating CBTM</strong> — para definir seu rating de entrada e garantir a integridade competitiva do Circuito.<br/><br/>
          <strong style={{color:"#e8edf2"}}>Histórico de partidas e resultados</strong> — para cálculo do ranking ELO e publicação no @clubedotenisdemesa.
        </div>

        <div style={{...s.box("#4ade80"), marginTop:8}}>
          <strong style={{color:"#4ade80", fontSize:13}}>Como usamos seus dados</strong><br/><br/>
          ✅ Gestão do Circuito (inscrições, partidas, ranking)<br/>
          ✅ Comunicação via WhatsApp e Instagram<br/>
          ✅ Publicação do ranking com nome e pontuação<br/>
          ❌ Seus dados <strong style={{color:"#e8edf2"}}>não são vendidos</strong> nem compartilhados com terceiros<br/>
          ❌ <strong style={{color:"#e8edf2"}}>Não coletamos</strong> CPF, endereço, e-mail ou dados financeiros
        </div>

        <div style={{...s.box("#a78bfa"), marginTop:8}}>
          <strong style={{color:"#a78bfa", fontSize:13}}>Seus direitos (Lei 13.709/2018 — LGPD)</strong><br/><br/>
          Você pode a qualquer momento solicitar ao administrador:<br/>
          📋 Acesso aos seus dados armazenados<br/>
          ✏️ Correção de dados incorretos<br/>
          🗑️ Exclusão dos seus dados (implica saída do Circuito)<br/>
          📤 Portabilidade dos seus dados<br/><br/>
          Contato: @clubedotenisdemesa no Instagram ou WhatsApp do grupo oficial.
        </div>

        <div style={{...s.box("#f87171"), marginTop:8}}>
          <strong style={{color:"#f87171", fontSize:12}}>Retenção de dados</strong><br/>
          Seus dados são mantidos enquanto você estiver ativo no Circuito e por até 2 anos após o encerramento da sua participação, para fins de histórico e auditoria de resultados.
        </div>

        <div style={s.checkRow} onClick={()=>setAceiteLGPD(v=>!v)}>
          <div style={s.checkBox(aceiteLGPD)}>
            {aceiteLGPD && <span style={{color:"#fff", fontSize:12, fontWeight:800}}>✓</span>}
          </div>
          <div style={{fontSize:12, color:"#8b9ab5", lineHeight:1.6}}>
            Li e compreendo a política de privacidade acima. <strong style={{color:"#e8edf2"}}>Consinto com a coleta e uso dos meus dados</strong> conforme descrito, de acordo com a Lei Geral de Proteção de Dados (LGPD — Lei 13.709/2018).
          </div>
        </div>

        <button style={s.btn(!aceiteLGPD)} onClick={()=>{ if(aceiteLGPD) setStep(3); }} disabled={!aceiteLGPD}>
          Continuar →
        </button>
      </div>
    </div>
  );

  // ── STEP 3: Aceite do regulamento ───────────────────────────────────────────
  if (step === 3) return (
    <div style={s.wrap}>
      <div style={{...s.card, marginTop:20}}>
        <button style={s.back} onClick={()=>setStep(2)}>← Voltar</button>
        <Steps/>
        <div style={s.title}>📋 Regulamento Oficial</div>
        <div style={s.sub}>Passo 3 de 3 · Leitura e aceite obrigatórios</div>

        {!lerReg ? (
          <>
            <div style={{...s.box("#4da3ff"), marginTop:8, fontSize:11}}>
              Antes de aceitar, você precisa ler o regulamento completo. Toque no botão abaixo para expandir os pontos principais.
            </div>
            <button onClick={()=>setLerReg(true)} style={{background:"rgba(26,115,200,0.15)",border:"1px solid rgba(26,115,200,0.3)",borderRadius:10,color:"#4da3ff",fontSize:13,fontWeight:700,padding:"12px",width:"100%",cursor:"pointer",marginTop:12}}>
              📖 Ler o Regulamento
            </button>
          </>
        ) : (
          <div style={{maxHeight:340, overflowY:"auto", marginTop:10, paddingRight:4}}>
            {[
              ["🏓 O Circuito","Circuito recreativo independente, não filiado à CBTM ou FMTMOP. Rating baseado na metodologia TTR/CBTM apenas como referência técnica."],
              ["👤 Elegibilidade","Temporada 1 exclusiva para homens com 18 anos ou mais. Federados e não-federados são bem-vindos."],
              ["⚙️ Formato","Rodadas quinzenais com pareamento por rating. Partidas em MD5 (melhor de 5 sets), 11 pontos por set."],
              ["📊 Rating vs. Ranking","Rating = nível técnico acumulado (nunca zera). Ranking = saldo de pontos da temporada (zera a cada temporada)."],
              ["⏱ Prazos","10 dias para realizar a partida. Até 24h após o jogo para registrar o placar em sets no app."],
              ["🔴 W.O. Culposo","Confirmou e não foi: −15 pts + aviso. Adversário recebe +8 pts. 2 W.O.s culposos = suspensão da temporada."],
              ["🚫 Fraude","Registro de resultado falso = banimento permanente do Circuito."],
              ["🏆 Torneio Final","Top 8 do ranking ao final da temporada disputam torneio presencial. Prêmios: troféu, medalhas e certificados."],
              ["💰 Mensalidade","Temporada 1 gratuita. A partir da T2: R$ 30/mês (R$ 90/temporada) ou R$ 81 à vista com desconto."],
              ["⚖️ Atletas Federados CBTM","Verifique com sua federação a conformidade com a Nota CBTM 183/2025 antes de participar."],
              ["📋 Disposições Gerais","Casos omissos decididos pelo administrador. O regulamento pode ser atualizado com aviso prévio."],
            ].map(([t,d]) => (
              <div key={t} style={{background:"#0d1825",borderRadius:8,padding:"10px 12px",marginBottom:6,borderLeft:"2px solid rgba(26,115,200,0.3)"}}>
                <div style={{fontSize:11,fontWeight:700,color:"#4da3ff",marginBottom:3}}>{t}</div>
                <div style={{fontSize:11,color:"#8b9ab5",lineHeight:1.6}}>{d}</div>
              </div>
            ))}
            <div style={{fontSize:10,color:"#374151",textAlign:"center",padding:"8px 0"}}>Regulamento completo disponível na tela inicial · v03-3</div>
          </div>
        )}

        {lerReg && (
          <div style={s.checkRow} onClick={()=>setAceiteReg(v=>!v)}>
            <div style={s.checkBox(aceiteReg)}>
              {aceiteReg && <span style={{color:"#fff",fontSize:12,fontWeight:800}}>✓</span>}
            </div>
            <div style={{fontSize:12,color:"#8b9ab5",lineHeight:1.6}}>
              Li o regulamento na íntegra e declaro que <strong style={{color:"#e8edf2"}}>aceito todas as regras, prazos e penalidades</strong> do Clube do Tênis de Mesa — Circuito BH (versão v03-3). Estou ciente do aviso sobre atletas federados pela CBTM.
            </div>
          </div>
        )}

        <button style={s.btn(!aceiteReg||!lerReg)} disabled={!aceiteReg||!lerReg} onClick={()=>{
          const agora = new Date().toISOString();
          if (onSubmit) onSubmit({
            name: name.trim(),
            phone: phone.trim(),
            federated: fed==="sim",
            rating: fed==="sim" && rating ? parseInt(rating) : (fed==="sim" ? null : 250),
            aceiteRegulamento: true,
            aceiteLGPD: true,
            dataAceite: agora,
          });
          setStep(4);
        }}>
          ✅ Confirmar inscrição
        </button>
      </div>
    </div>
  );

  // ── STEP 4: Sucesso ────────────────────────────────────────────────────────
  return (
    <div style={s.wrap}>
      <div style={{...s.card, textAlign:"center", marginTop:40}}>
        <div style={{fontSize:48, marginBottom:16}}>✅</div>
        <div style={{fontSize:16, fontWeight:800, color:"#e8edf2", marginBottom:8}}>Inscrição enviada!</div>
        <div style={{fontSize:13, color:"#8b9ab5", marginBottom:16, lineHeight:1.6}}>
          O administrador vai revisar seu cadastro e entrar em contato pelo WhatsApp em breve.
        </div>
        <div style={{background:"rgba(74,222,128,0.08)", border:"1px solid rgba(74,222,128,0.2)", borderRadius:10, padding:"12px 14px", marginBottom:16, textAlign:"left"}}>
          <div style={{fontSize:11, fontWeight:700, color:"#4ade80", marginBottom:8}}>✓ Registrado com sucesso</div>
          <div style={{fontSize:11, color:"#6b7a8d", lineHeight:1.8}}>
            📋 Aceite do regulamento v03-3<br/>
            🔒 Consentimento LGPD (Lei 13.709/2018)<br/>
            📅 Data/hora: {new Date().toLocaleString("pt-BR")}
          </div>
        </div>
        {onBack && <button style={s.btn(false)} onClick={onBack}>Voltar ao início</button>}
      </div>
    </div>
  );
}

// ── MAIN APP ─────────────────────────────────────────────────────────────────



// ── REGULAMENTO VIEW (regulamento v03-3) ─────────────────────────────────────
function RegulamentoView({ onBack }) {
  const [capAberto, setCapAberto] = useState(null);

  const s = {
    wrap: { minHeight:"100vh", background:"#0a1628", fontFamily:"Inter,sans-serif", paddingBottom:40 },
    aviso: { background:"rgba(249,168,37,0.1)", borderLeft:"3px solid #f9a825", padding:"12px 14px", fontSize:11, color:"rgba(255,255,255,0.75)", lineHeight:1.7 },
    header: { background:"linear-gradient(135deg,#1a73c8,#0d5aa7)", padding:"14px 16px", display:"flex", alignItems:"center", gap:10 },
    logoWrap: { width:38,height:38,borderRadius:"50%",overflow:"hidden",border:"2px solid rgba(255,255,255,0.3)",flexShrink:0 },
    backBtn: { background:"rgba(255,255,255,0.12)",border:"none",borderRadius:8,color:"rgba(255,255,255,0.8)",fontSize:11,fontWeight:700,padding:"5px 10px",cursor:"pointer" },
    body: { padding:"12px 14px" },
    capCard: (ab) => ({ background:ab?"#162035":"#111d2b", borderRadius:12, marginBottom:8, border:ab?"1px solid rgba(26,115,200,0.35)":"1px solid rgba(255,255,255,0.05)", overflow:"hidden", cursor:"pointer" }),
    capHeader: { display:"flex", alignItems:"center", justifyContent:"space-between", padding:"13px 14px" },
    capTag: { fontSize:9, fontWeight:700, color:"#4da3ff", textTransform:"uppercase", letterSpacing:1, marginBottom:3 },
    capTitulo: { fontSize:13, fontWeight:700, color:"#e8edf2" },
    capSeta: (ab) => ({ fontSize:12, color:"#6b7a8d", transform:ab?"rotate(90deg)":"rotate(0deg)", transition:"transform 0.2s" }),
    capBody: { padding:"0 14px 14px", borderTop:"1px solid rgba(255,255,255,0.05)" },
    p: { fontSize:12, color:"#8b9ab5", lineHeight:1.7, marginTop:8 },
    li: { fontSize:12, color:"#8b9ab5", lineHeight:1.7, marginBottom:4 },
    dest: { color:"#e8edf2", fontWeight:600 },
    box: (cor) => ({ background:`${cor}11`, border:`1px solid ${cor}33`, borderLeft:`3px solid ${cor}`, borderRadius:8, padding:"10px 12px", marginTop:10 }),
    bTit: { fontSize:11, fontWeight:700, color:"#e8edf2", marginBottom:5 },
    tbl: { width:"100%", borderCollapse:"collapse", marginTop:10, fontSize:11 },
    th: { background:"rgba(26,115,200,0.2)", color:"#4da3ff", fontWeight:700, padding:"7px 8px", textAlign:"left", fontSize:10, textTransform:"uppercase", letterSpacing:0.5 },
    td: { padding:"7px 8px", borderBottom:"1px solid rgba(255,255,255,0.05)", color:"#8b9ab5", verticalAlign:"top" },
    tdd: { padding:"7px 8px", borderBottom:"1px solid rgba(255,255,255,0.05)", color:"#e8edf2", fontWeight:600, verticalAlign:"top" },
  };

  const caps = [
    { id:1,  tag:"Cap. 01", titulo:"Como Funciona: O Ciclo do Ranking" },
    { id:2,  tag:"Cap. 02", titulo:"Elegibilidade — Quem Pode Participar" },
    { id:3,  tag:"Cap. 03", titulo:"Sistema de Pareamento" },
    { id:4,  tag:"Cap. 04", titulo:"Reputação & Comprovação" },
    { id:5,  tag:"Cap. 05", titulo:"Sistema de Rating — Metodologia CBTM" },
    { id:6,  tag:"Cap. 06", titulo:"Regras das Partidas" },
    { id:7,  tag:"Cap. 07", titulo:"W.O., Faltas & Penalidades" },
    { id:8,  tag:"Cap. 08", titulo:"Registro do Placar" },
    { id:9,  tag:"Cap. 09", titulo:"Ranking & Publicação" },
    { id:10, tag:"Cap. 10", titulo:"Torneio Presencial de Encerramento" },
    { id:11, tag:"Cap. 11", titulo:"Como Participar" },
    { id:12, tag:"Cap. 12", titulo:"Mensalidades, Inadimplência & Desistência" },
    { id:13, tag:"Cap. 13", titulo:"Estrutura das Rodadas & Calendário Anual" },
    { id:14, tag:"Cap. 14", titulo:"Casos Omissos" },
  ];

  function Ul({ items }) {
    return <ul style={{paddingLeft:16,marginTop:6}}>{items.map((i,k)=><li key={k} style={s.li}>{i}</li>)}</ul>;
  }
  function Box({ cor, titulo, children }) {
    return <div style={s.box(cor)}><div style={s.bTit}>{titulo}</div>{children}</div>;
  }
  function Tbl({ headers, rows }) {
    return (
      <table style={s.tbl}>
        <thead><tr>{headers.map(h=><th key={h} style={s.th}>{h}</th>)}</tr></thead>
        <tbody>{rows.map((r,i)=><tr key={i}>{r.map((c,j)=><td key={j} style={j===0?s.tdd:s.td}>{c}</td>)}</tr>)}</tbody>
      </table>
    );
  }

  function ConteudoCap({ id }) {
    if (id===1) return (
      <div>
        <p style={s.p}>O Clube do Tênis de Mesa funciona em <span style={s.dest}>rodadas fixas</span>. No início de cada rodada, o sistema — baseado no ranking atual — define quem joga contra quem. Os jogadores têm um prazo para realizar a partida onde e quando quiserem, e registram o placar. O resultado atualiza o ranking e define os confrontos da próxima rodada.</p>
        <Box cor="#4da3ff" titulo="🔄 O Fluxo em 5 Passos">
          <Ul items={[
            "🗓️ Abertura — todo dia 1º e 16, o sistema publica os confrontos no Instagram e no grupo WhatsApp",
            "📲 Contato — jogadores combinam data e local (dias 1–3)",
            "🏓 Partida — jogam em qualquer mesa em boas condições (dias 4–10)",
            "📊 Registro — ambos registram o placar em sets em até 24h após o jogo",
            "🔄 Atualização — sistema processa, atualiza o rating ELO e gera a próxima rodada (dia 15)",
          ]}/>
        </Box>
        <Box cor="#4ade80" titulo="⚖️ Pareamento Inteligente">
          <p style={s.p}>O sistema pareia jogadores de rating próximo, priorizando quem ainda não se enfrentou na temporada.</p>
        </Box>
      </div>
    );
    if (id===2) return (
      <div>
        <p style={s.p}>A <span style={s.dest}>Temporada Inaugural</span> é exclusiva para homens com 18 anos ou mais. O ranking masculino adulto é o ponto de partida e o modelo de referência para todas as expansões futuras.</p>
        <Tbl headers={["Perfil","Temporada 1","Observação"]} rows={[
          ["Homem, 18+, qualquer nível","✅ ELEGÍVEL","Federado ou não-federado — todos bem-vindos"],
          ["Homem, menos de 18 anos","⛔ AGUARDAR","Modalidade futura"],
          ["Mulher, qualquer idade","⛔ AGUARDAR","Modalidade futura"],
          ["Atleta federado CBTM","✅ ELEGÍVEL","Entra com rating CBTM-Web verificado"],
          ["Atleta não-federado","✅ ELEGÍVEL","Entra com 250 pts"],
        ]}/>
        <Box cor="#f87171" titulo="⚠️ Atletas com TRA ativa na CBTM">
          <p style={s.p}>Verifique junto à sua federação se a participação em eventos não-oficiais é permitida. O administrador e @clubedotenisdemesa não se responsabilizam por eventuais sanções desportivas aplicadas por entidades federativas.</p>
        </Box>
      </div>
    );
    if (id===3) return (
      <div>
        <p style={s.p}>O sistema pareia os jogadores de forma inteligente a cada rodada, garantindo confrontos equilibrados e progressão natural no ranking.</p>
        <Box cor="#4da3ff" titulo="⚖️ Rating Próximo">
          <p style={s.p}>Jogadores são pareados com adversários de rating mais próximo. Quanto menor a diferença de rating, mais equilibrado o confronto.</p>
        </Box>
        <Box cor="#4ade80" titulo="🔀 Anti-Repetição">
          <p style={s.p}>O sistema evita repetir o mesmo confronto na mesma temporada. Só repete se não houver outro adversário disponível de nível similar.</p>
        </Box>
        <Box cor="#facc15" titulo="📈 Ascensão Natural">
          <p style={s.p}>Jogadores que ganham vão subindo no ranking e enfrentando adversários mais fortes ao longo da temporada.</p>
        </Box>
      </div>
    );
    if (id===4) return (
      <div>
        <p style={s.p}>Para garantir confiança nos resultados, o Circuito adota um sistema simples de reputação baseado em comprovação fotográfica — totalmente opcional, mas recomendado.</p>
        <Box cor="#4da3ff" titulo="📸 Como Funciona">
          <Ul items={[
            "Foto dos dois jogadores juntos após a partida ativa o Nível 2 de Reputação",
            "Não é obrigatório — o registro do placar pelo formulário já é válido sozinho",
            "Em casos de disputa ou W.O., comprovantes fotográficos têm peso decisivo",
            "Atletas com bom histórico de comprovação têm prioridade em casos de impasse",
          ]}/>
        </Box>
      </div>
    );
    if (id===5) return (
      <div>
        <p style={s.p}>O Clube do Tênis de Mesa adota, como referência técnica, a metodologia de cálculo de rating do sistema TTR/CBTM — o mesmo padrão usado nas competições nacionais brasileiras. Vencer quem tem mais pontos vale pouco; vencer quem tem menos pontos vale mais ainda para o azarão.</p>
        <Box cor="#facc15" titulo="📖 Rating vs. Ranking">
          <Ul items={[
            "Rating — número absoluto do nível técnico. Começa em 250 pts (não-federados) ou no valor CBTM (federados). Nunca zera.",
            "Ranking — saldo de pontos conquistados na temporada. Zera a cada nova temporada.",
          ]}/>
        </Box>
        <Tbl headers={["Diferença","✅ Esp. vencedor","✅ Esp. perdedor","⚡ Inesp. vencedor","⚡ Inesp. perdedor"]} rows={[
          ["0–49 pts","+14 pts","−7 pts","+28 pts","−14 pts"],
          ["50–99 pts","+12 pts","−6 pts","+24 pts","−12 pts"],
          ["100–149 pts","+10 pts","−5 pts","+20 pts","−10 pts"],
          ["150–199 pts","+8 pts","−4 pts","+16 pts","−8 pts"],
          ["200–299 pts","+6 pts","−3 pts","+12 pts","−6 pts"],
          ["300–399 pts","+4 pts","−2 pts","+46 pts","−23 pts"],
          ["400+ pts","+2 pts","−1 pt","+50+ pts","−25+ pts"],
        ]}/>
        <Box cor="#f87171" titulo="🚫 Autodeclaração Proibida para Federados">
          <p style={s.p}>O admin solicita comprovante do cadastro CBTM-Web antes de confirmar a inscrição. A tentativa de fraude no rating de entrada resulta em suspensão imediata.</p>
        </Box>
        <Box cor="#4da3ff" titulo="🏅 Tabela de Níveis — Referência TTR/CBTM">
          <Tbl headers={["Faixa","Nível","Perfil"]} rows={[
            ["0–249","🔰 Entrada","Abaixo de 250 / sem ranking ativo"],
            ["250–499","🥉 Bronze","Iniciante"],
            ["700–999","🥈 Prata","Amador"],
            ["1000–1299","🥇 Ouro","Intermediário"],
            ["1300–1699","💎 Platina","Avançado / Clubista"],
            ["1700–2199","💠 Diamante","Federado / Regional"],
            ["2200+","👑 Elite","Nacional / Top BR"],
          ]}/>
        </Box>
      </div>
    );
    if (id===6) return (
      <div>
        <p style={s.p}>Formato obrigatório: <span style={s.dest}>Melhor de 5 sets (MD5)</span>, regras oficiais ITTF 2026. Jogos em formato diferente (MD3, partida única, etc.) não são aceitos.</p>
        <Box cor="#4ade80" titulo="🏆 Jogos em Torneios Externos — Válidos para o Ranking">
          <Ul items={[
            "Partidas entre atletas do Circuito disputadas em torneios externos podem ser aproveitadas como o confronto oficial",
            "Comprovação: placar em sets + print da chave/súmula ou foto dos dois jogadores juntos",
            "Limite: apenas 1 jogo por rodada pode ser aproveitado desta forma",
            "Aproveitamento é opcional — mesmo já tendo se enfrentado, os atletas podem preferir jogar o confronto do Circuito separadamente",
          ]}/>
        </Box>
      </div>
    );
    if (id===7) return (
      <div>
        <Box cor="#f87171" titulo="🔴 W.O. Culposo — Comprovação obrigatória pelo atleta abandonado">
          <p style={s.p}>Confirmou a partida e não compareceu sem comunicação prévia. Exige os dois comprovantes: 📸 foto do local no horário acordado E 📱 print da conversa confirmando data/horário/local por ambos os lados. Sem os dois: tratado como W.O. justificado ou impasse.</p>
        </Box>
        <Tbl headers={["Situação","Classificação","Consequência"]} rows={[
          ["Confirmou e não foi — comprovado","W.O. CULPOSO","−15 pts ELO + aviso. Adversário ganha +8 pts."],
          ["Impossibilidade justificada","W.O. JUSTIFICADO","Rodada anulada. Nenhum perde pontos."],
          ["Adversário sumiu desde o início","W.O. A FAVOR","Comunicar em até 48h com print das tentativas. +8 pts."],
          ["2 W.O.s culposos na temporada","SUSPENSÃO","Excluído da temporada em curso. Volta na seguinte."],
          ["Registro de resultado falso","EXCLUSÃO","Banimento permanente do Circuito."],
          ["Registro fora do prazo (após 24h)","RESULTADO INVÁLIDO","Partida não computada. Sem pontos para ambos."],
        ]}/>
        <Box cor="#4da3ff" titulo="💬 Como Comunicar um W.O.">
          <Ul items={[
            "Enviar ao admin pelo WhatsApp do grupo em até 48h antes do fim da rodada",
            "Anexar foto do local + print da conversa com confirmação da partida",
            "Admin analisa e classifica: culposo, justificado ou impasse",
            "Sem comprovantes suficientes: rodada anulada para ambos",
          ]}/>
        </Box>
      </div>
    );
    if (id===8) return (
      <div>
        <p style={s.p}>O registro é simples e feito por ambos os jogadores pelo formulário fixado no grupo. Em caso de divergência, o administrador decide com base em comprovantes.</p>
        <Box cor="#4ade80" titulo="✅ O Que Registrar">
          <Ul items={[
            "Nomes dos dois jogadores (conforme cadastro)",
            "Data e local da partida",
            "Placar em sets — ex: 3×1 ou 3×0 (não é necessário informar os pontos de cada set)",
            "Nome do vencedor",
          ]}/>
        </Box>
        <Box cor="#4da3ff" titulo="📲 Canais de Registro">
          <Ul items={[
            "Formulário Google Forms — link fixado no grupo WhatsApp e no Instagram (canal oficial)",
            "Foto dos dois jogadores juntos (opcional — ativa o Nível 2 de Reputação)",
            "Direct Instagram @clubedotenisdemesa — confirmação em até 2h",
            "Mensagem no grupo — apenas como backup",
          ]}/>
        </Box>
        <Box cor="#f87171" titulo="⚠️ Atenção aos Prazos">
          <Ul items={[
            "Registrar em até 24 horas após a partida",

          ]}/>
        </Box>
        <Box cor="#f87171" titulo="🚪 Desistência">
          <Tbl headers={["Momento","Aviso mínimo","Mensalidade devida","Rating"]} rows={[
            ["Antes da próxima rodada","48h","Parcelas vencidas — sem reembolso restante","✅ Congelado"],

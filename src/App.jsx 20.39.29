// ── ELO ─────────────────────────────────────────────────────────────────────
function calcElo(ra, rb, result) {
  const K = 32, E = 1 / (1 + Math.pow(10, (rb - ra) / 400));
  return Math.round(ra + K * (result - E));
}

// ── ROUND ROBIN ──────────────────────────────────────────────────────────────
function generateRoundRobin(players) {
  const n = players.length;
  const list = n % 2 === 0 ? [...players] : [...players, null];
  const rounds = [];
  for (let r = 0; r < list.length - 1; r++) {
    const matches = [];
    for (let i = 0; i < list.length / 2; i++) {
      const a = list[i], b = list[list.length - 1 - i];
      if (a && b) matches.push({ p1: a, p2: b });
    }
    rounds.push(matches);
    list.splice(1, 0, list.pop());
  }
  return rounds;
}

// ── REDUCER ──────────────────────────────────────────────────────────────────
const INIT = {
  athletes: [],          // {id, name, phone, federated, rating, status, key}
  waitlist: [],
  keys: [],              // [{id, name, athletes:[ids], rounds, currentRound}]
  phase: "inscricoes",   // inscricoes | etapa | finalizado
  pendingResults: [],    // {matchId, p1Score, p2Score, p1Id, p2Id, submittedBy, status}
  matches: [],           // {id, keyId, round, p1Id, p2Id, score1, score2, validated, deadline}
  results: [],           // validated match results
};

function reducer(state, action) {
  switch (action.type) {

    case "INSCRICAO_ADD": {
      const { name, phone, federated, rating, aceiteRegulamento, aceiteLGPD, dataAceite, ipAceite } = action.payload;
      const id = Date.now();
      const ath = {
        id, name, phone, federated,
        rating: federated ? (rating || null) : 250,
        status: "pendente", key: null,
        // Aceite do regulamento
        aceiteRegulamento: aceiteRegulamento || false,
        dataAceiteRegulamento: dataAceite || null,
        versaoRegulamento: "v03-3",
        // Consentimento LGPD
        aceiteLGPD: aceiteLGPD || false,
        dataAceiteLGPD: dataAceite || null,
        // Auditoria
        inscritoEm: dataAceite || new Date().toISOString(),
      };
      return { ...state, athletes: [...state.athletes, ath] };
    }

    case "INSCRICAO_VALIDAR": {
      const { id, rating, approved, motivo } = action.payload;
      if (approved) {
        const updated = state.athletes.map(a =>
          a.id === id ? { ...a, status: "ativo", rating: rating || a.rating, ratingInicial: rating || a.rating, saldoTemp: 0 } : a
        );
        return { ...state, athletes: updated };
      } else {
        const updated = state.athletes.map(a =>
          a.id === id ? { ...a, status: "reprovado", motivo } : a
        );
        return { ...state, athletes: updated };
      }
    }

    case "INICIAR_ETAPA": {
      const { numKeys } = action.payload;
      const ativos = state.athletes.filter(a => a.status === "ativo");
      const sorted = [...ativos].sort((a, b) => b.rating - a.rating);
      const perKey = Math.ceil(sorted.length / numKeys);
      const keys = [];
      const athletesUpdated = [...state.athletes];

      for (let k = 0; k < numKeys; k++) {
        const slice = sorted.slice(k * perKey, (k + 1) * perKey);
        const keyId = `key_${k + 1}`;
        const keyName = numKeys === 1 ? "Chave Única" : `Chave ${String.fromCharCode(65 + k)}`;
        slice.forEach(a => {
          const idx = athletesUpdated.findIndex(x => x.id === a.id);
          athletesUpdated[idx] = { ...athletesUpdated[idx], key: keyId };
        });
        const rounds = generateRoundRobin(slice.map(a => a.id));
        keys.push({ id: keyId, name: keyName, athleteIds: slice.map(a => a.id), rounds, currentRound: 0 });
      }

      // Gerar partidas da rodada 1
      const matchDeadline = new Date();
      matchDeadline.setDate(matchDeadline.getDate() + 10);
      const matchDeadlineStr = matchDeadline.toISOString().split("T")[0];
      const scoreDeadline = new Date();
      scoreDeadline.setDate(scoreDeadline.getDate() + 14); // 10 + 4
      const scoreDeadlineStr = scoreDeadline.toISOString().split("T")[0];
      const matches = [];
      keys.forEach(k => {
        (k.rounds[0] || []).forEach(pair => {
          matches.push({
            id: `m_${Date.now()}_${Math.random().toString(36).slice(2,6)}`,
            keyId: k.id, round: 1,
            p1Id: pair.p1, p2Id: pair.p2,
            score1: null, score2: null,
            p1Submitted: null, p2Submitted: null,
            validated: false,
            deadline: matchDeadlineStr,
            scoreDeadline: scoreDeadlineStr
          });
        });
      });

      return { ...state, athletes: athletesUpdated, keys, matches, phase: "etapa" };
    }

    case "SUBMIT_RESULT": {
      const { matchId, athleteId, score1, score2 } = action.payload;
      const updated = state.matches.map(m => {
        if (m.id !== matchId) return m;
        if (m.p1Id === athleteId) return { ...m, p1Submitted: { score1, score2 }, p1SubAt: new Date().toISOString() };
        if (m.p2Id === athleteId) return { ...m, p2Submitted: { score1, score2 }, p2SubAt: new Date().toISOString() };
        return m;
      });
      return { ...state, matches: updated };
    }

    case "VALIDATE_RESULT": {
      const { matchId, approved, motivo } = action.payload;
      if (!approved) {
        const updated = state.matches.map(m =>
          m.id === matchId ? { ...m, rejeitado: true, motivoRejeicao: motivo } : m
        );
        return { ...state, matches: updated };
      }
      const match = state.matches.find(m => m.id === matchId);
      const p1wins = match.p1Submitted.score1 > match.p1Submitted.score2;
      const p1 = state.athletes.find(x => x.id === match.p1Id);
      const p2 = state.athletes.find(x => x.id === match.p2Id);
      const newR1 = calcElo(p1.rating, p2.rating, p1wins ? 1 : 0);
      const newR2 = calcElo(p2.rating, p1.rating, p1wins ? 0 : 1);
      const delta1 = newR1 - p1.rating;
      const delta2 = newR2 - p2.rating;
      const athletes = state.athletes.map(a => {
        if (a.id === match.p1Id) {
          return { ...a, rating: newR1, saldoTemp: (a.saldoTemp||0) + delta1, wins: (a.wins||0) + (p1wins?1:0), losses: (a.losses||0) + (p1wins?0:1) };
        }
        if (a.id === match.p2Id) {
          return { ...a, rating: newR2, saldoTemp: (a.saldoTemp||0) + delta2, wins: (a.wins||0) + (p1wins?0:1), losses: (a.losses||0) + (p1wins?1:0) };
        }
        return a;
      });
      const matches = state.matches.map(m =>
        m.id === matchId ? { ...m, validated: true, score1: m.p1Submitted.score1, score2: m.p1Submitted.score2 } : m
      );
      return { ...state, athletes, matches };
    }

    case "AVANCAR_RODADA": {
      const keys = state.keys.map(k => ({ ...k, currentRound: k.currentRound + 1 }));
      const matchDeadline2 = new Date();
      matchDeadline2.setDate(matchDeadline2.getDate() + 10);
      const matchDeadlineStr2 = matchDeadline2.toISOString().split("T")[0];
      const scoreDeadline2 = new Date();
      scoreDeadline2.setDate(scoreDeadline2.getDate() + 14);
      const scoreDeadlineStr2 = scoreDeadline2.toISOString().split("T")[0];
      const newMatches = [];
      keys.forEach(k => {
        const nextRound = k.rounds[k.currentRound] || [];
        nextRound.forEach(pair => {
          newMatches.push({
            id: `m_${Date.now()}_${Math.random().toString(36).slice(2,6)}`,
            keyId: k.id, round: k.currentRound + 1,
            p1Id: pair.p1, p2Id: pair.p2,
            score1: null, score2: null,
            p1Submitted: null, p2Submitted: null,
            validated: false,
            deadline: matchDeadlineStr2,
            scoreDeadline: scoreDeadlineStr2
          });
        });
      });
      return { ...state, keys, matches: [...state.matches, ...newMatches] };
    }

    case "LOAD_FROM_DB": {
      const { athletes, matches, keys, phase } = action.payload;
      return { ...state, athletes, matches, keys, phase };
    }

    case "EDITAR_ATLETA": {
      const { id, nome, telefone, rating, status } = action.payload;
      const athletes = state.athletes.map(a =>
        a.id === id ? { ...a, name: nome, phone: telefone, rating, status } : a
      );
      return { ...state, athletes };
    }

    case "EXCLUIR_ATLETA": {
      const athletes = state.athletes.filter(a => a.id !== action.payload.id);
      return { ...state, athletes };
    }

    default: return state;
  }
}

// ── UTILS ────────────────────────────────────────────────────────────────────
const fmtDate = d => d ? d.split("-").reverse().join("/") : "-";
const medalColor = i => i===0?"#FFD700":i===1?"#C0C0C0":i===2?"#CD7F32":"#6B7280";
function deadlineStatus(dateStr) {
  if (!dateStr) return { color:"#6b7a8d", label:"", urgent:false };
  const today = new Date(); today.setHours(0,0,0,0);
  const deadline = new Date(dateStr);
  const days = Math.ceil((deadline - today) / (1000*60*60*24));
  if (days < 0) return { color:"#f87171", label:`⚠️ Vencido há ${Math.abs(days)}d`, urgent:true };
  if (days === 0) return { color:"#f87171", label:"⚠️ Vence hoje!", urgent:true };
  if (days <= 2) return { color:"#fb923c", label:`🔥 ${days}d restante${days>1?"s":""}`, urgent:true };
  if (days <= 5) return { color:"#facc15", label:`⏰ ${days}d restantes`, urgent:false };
  return { color:"#6b7a8d", label:`até ${fmtDate(dateStr)}`, urgent:false };
}

